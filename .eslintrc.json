{
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:react/recommended"
  ],
  "parserOptions": {
    "ecmaFeatures": { "jsx": true },
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["react"],
  "settings": {
    "react": { "version": "detect" }
  },

  "overrides": [
  {
    "files": ["**/*.test.js", "**/*.test.jsx"],
    "env": {
      "browser": true,
      "node": true
    },
    "globals": {
      "describe": "readonly",
      "it": "readonly",
      "expect": "readonly",
      "beforeEach": "readonly",
      "afterEach": "readonly"
    }
  }
],

  "rules": {
    "react/react-in-jsx-scope": "off"
  }
}